<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HocaKapidaApp.MainPage"
             BackgroundColor="Black">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30">

            <Label Text="Hoca Kapıda Sistemi" FontSize="26" HorizontalOptions="Center" FontAttributes="Bold" TextColor="#007BFF"/>

            <Frame BackgroundColor="DarkBlue" CornerRadius="12" Padding="20" BorderColor="#1E1E1E">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="HocaIsimLabel" Text="Hoca: Bekleniyor..." FontSize="18" HorizontalOptions="Center" TextColor="White"/>
                    <Label x:Name="DurumLabel" Text="Durum: Lütfen Durum Seçin" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White"/>
                    <Label x:Name="OzelMesajLabel" Text="Not: Yok" FontSize="16" FontAttributes="Italic" HorizontalOptions="Center" TextColor="LightGray"/>
                </VerticalStackLayout>
            </Frame>

            <Entry x:Name="MesajKutusu" 
                   Placeholder="Öğrencilere bir not bırakın..." 
                   BackgroundColor="White" 
                   TextColor="Black" 
                   Margin="0,10,0,10"/>

            <Button Text="🟢 Odada (Müsait)" BackgroundColor="Green" TextColor="White" Clicked="OdadaButonunaBasildi"/>
            <Button Text="🔴 Derste" BackgroundColor="DarkRed" TextColor="White" Clicked="DersteButonunaBasildi"/>
            <Button Text="⚪ Kampüs Dışında" BackgroundColor="DimGray" TextColor="White" Clicked="DisaridaButonunaBasildi"/>
            <Button Text="🚫 Rahatsız Etmeyin" BackgroundColor="Red" TextColor="White" Clicked="RahatsizEtmeyinButonunaBasildi"/>

            <BoxView HeightRequest="2" Color="#007BFF" Margin="0,10,0,10" />

            <Label Text="📩 Gelen Bildirimler" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Start"/>

            <CollectionView x:Name="BildirimlerListesi" EmptyView="Henüz bildirim yok." HeightRequest="350">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#1E1E1E" BorderColor="#007BFF" Margin="0,5" Padding="10" CornerRadius="10">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="{Binding tur}" FontAttributes="Bold" TextColor="#007BFF" FontSize="14"/>
                                        <Label Text="{Binding tarih}" FontSize="12" TextColor="#AAAAAA" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding mesaj}" FontSize="15" TextColor="White" LineBreakMode="WordWrap"/>
                                </VerticalStackLayout>

                                <Button Grid.Column="1" Text="🗑️" BackgroundColor="Transparent" 
                            FontSize="18" VerticalOptions="Center"
                            Clicked="BildirimSilClicked" CommandParameter="{Binding .}"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>